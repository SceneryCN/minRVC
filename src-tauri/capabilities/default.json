{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "默认能力：允许前端调用核心命令、读写应用数据目录、打开外部链接",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "shell:allow-open",
    "dialog:default",
    "fs:default",
    "fs:allow-app-write",
    "fs:allow-app-read"
  ]
}
