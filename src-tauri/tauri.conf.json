{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "声变",
  "version": "0.1.0",
  "identifier": "com.rvc.voicechanger",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "声变 - RVC 实时变声器",
        "width": 1100,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; img-src 'self' data: tauri: asset:; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:* ipc: tauri:; script-src 'self' tauri: 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "category": "Music",
    "shortDescription": "傻瓜式实时 RVC 变声器",
    "longDescription": "基于 RVC（Retrieval-based Voice Conversion）的实时变声器，提供 5 种预设音色，配合 VB-Cable 虚拟声卡接入直播链路。",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": []
    },
    "fs": {
      "scope": ["$APPDATA/**", "$APPLOCALDATA/**", "$HOME/Documents/**"]
    },
    "dialog": {}
  }
}
